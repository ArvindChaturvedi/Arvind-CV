apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: {{ ingress_name }}
  annotations:
    {{ ingress_annotations | to_yaml | indent(6) }}
spec:
  rules:
    - host: {{ host }}
      http:
        paths:
          - path: {{ path }}
            pathType: {{ path_type }}
            backend:
              service:
                name: {{ service_name }}
                port:
                  number: {{ service_port }}
